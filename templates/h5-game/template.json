{
  "schema_version": "2.0",
  "id": "h5-game",
  "name": "H5 游戏",
  "description": "Phaser 3 + TypeScript - 2D H5 游戏开发引擎",
  "category": "game",
  "phase": 3,
  "icon": "🎮",
  "source": {
    "repo_url": "https://github.com/MarcusYuan/HiveLaunch",
    "template_path": "templates/h5-game",
    "default_ref": "main"
  },
  "variables": [
    {
      "key": "PROJECT_NAME",
      "label": "项目名称",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "placeholder": "my-h5-game",
      "description": "项目名称，仅小写字母、数字和连字符"
    },
    {
      "key": "DISPLAY_NAME",
      "label": "显示名称",
      "type": "string",
      "placeholder": "My H5 Game",
      "description": "游戏显示的名称"
    },
    {
      "key": "VERSION",
      "label": "版本号",
      "type": "string",
      "default": "0.1.0",
      "description": "游戏版本"
    }
  ],
  "files": [
    {
      "template": "package.json.tmpl",
      "output": "package.json"
    }
  ],
  "runtimes": [
    { "id": "opencode", "name": "OpenCode", "config_refs": [".opencode/oh-my-opencode.jsonc", "opencode.json"] }
  ],
  "agent_packs": [
    { "id": "default-pack", "name": "Default Agent Pack", "compatible_runtimes": ["opencode"], "artifact_refs": ["AGENTS.md", "CLAUDE.md", ".opencode/skills/"] }
  ],
  "skills": [
    "typescript-expert",
    "emilkowal-animations"
  ],
  "defaults": {
    "runtime_id": "opencode",
    "agent_pack_id": "default-pack"
  },
  "recommended_swarms": [
    { "id": "game-dev-swarm" }
  ],
  "post_clone_script": [
    "pnpm install"
  ]
}
