{
  "schema_version": "2.0",
  "id": "tauri-desktop",
  "name": "Tauri 桌面应用",
  "description": "Tauri v2 + React 19 + TypeScript + Tailwind CSS",
  "category": "desktop",
  "phase": 1,
  "icon": "💻",
  "source": {
    "repo_url": "https://github.com/MarcusYuan/HiveLaunch-Templates",
    "template_path": "templates/tauri-desktop",
    "default_ref": "main"
  },
  "variables": [
    {
      "key": "PROJECT_NAME",
      "label": "项目名称",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "placeholder": "my-desktop-app",
      "description": "项目名称，仅小写字母、数字和连字符"
    },
    {
      "key": "DISPLAY_NAME",
      "label": "显示名称",
      "type": "string",
      "placeholder": "My Desktop App",
      "description": "应用显示名称"
    },
    {
      "key": "BUNDLE_ID",
      "label": "Bundle ID",
      "type": "string",
      "pattern": "^[a-z][a-z0-9.]*$",
      "placeholder": "com.company.myapp",
      "default": "com.hivelaunch.{{PROJECT_NAME}}",
      "description": "应用包标识符"
    }
  ],
  "files": [
    {
      "template": "package.json.tmpl",
      "output": "package.json"
    },
    {
      "template": "src-tauri/tauri.conf.json.tmpl",
      "output": "src-tauri/tauri.conf.json"
    },
    {
      "template": "src-tauri/Cargo.toml.tmpl",
      "output": "src-tauri/Cargo.toml"
    }
  ],
  "runtimes": [
    { "id": "opencode", "name": "OpenCode", "config_refs": [".opencode/oh-my-opencode.jsonc", "opencode.json"] }
  ],
  "agent_packs": [
    { "id": "default-pack", "name": "Default Agent Pack", "compatible_runtimes": ["opencode"], "artifact_refs": ["AGENTS.md", "CLAUDE.md", ".opencode/skills/"] }
  ],
  "skills": [
    "rust-desktop-applications",
    "typescript-expert",
    "tailwind-v4-shadcn"
  ],
  "defaults": {
    "runtime_id": "opencode",
    "agent_pack_id": "default-pack"
  },
  "recommended_swarms": [
    { "id": "desktop-swarm" }
  ],
  "post_clone_script": [
    "pnpm install",
    "cd src-tauri && cargo fetch"
  ]
}
