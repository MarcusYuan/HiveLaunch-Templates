{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "{{DISPLAY_NAME}}",
  "version": "1.0.0",
  "identifier": "{{BUNDLE_ID}}",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "{{DISPLAY_NAME}}",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
