{
  "schema_version": "2.0",
  "id": "ai-web-app",
  "name": "AI Web 应用",
  "description": "Next.js 15 + Vercel AI SDK + LangChain + shadcn/ui",
  "category": "ai",
  "phase": 1,
  "icon": "🤖",
  "source": {
    "repo_url": "https://gitee.com/hivelaunch/hivelaunch.git",
    "template_path": "templates/ai-web-app",
    "default_ref": "master"
  },
  "variables": [
    {
      "key": "PROJECT_NAME",
      "label": "项目名称",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "placeholder": "my-ai-app",
      "description": "项目名称，仅小写字母、数字和连字符"
    },
    {
      "key": "DISPLAY_NAME",
      "label": "显示名称",
      "type": "string",
      "placeholder": "My AI App",
      "description": "应用显示名称"
    }
  ],
  "files": [
    {
      "template": "package.json.tmpl",
      "output": "package.json"
    }
  ],
  "env_example": ".env.local.example",
  "runtimes": [
    { "id": "opencode", "name": "OpenCode", "config_refs": [".opencode/oh-my-opencode.jsonc", "opencode.json"] }
  ],
  "agent_packs": [
    { "id": "default-pack", "name": "Default Agent Pack", "compatible_runtimes": ["opencode"], "artifact_refs": ["AGENTS.md", "CLAUDE.md", ".opencode/skills/"] }
  ],
  "skills": [
    "vercel-react-best-practices",
    "langgraph-docs",
    "tanstack-query-best-practices",
    "tailwind-v4-shadcn",
    "typescript-expert"
  ],
  "defaults": {
    "runtime_id": "opencode",
    "agent_pack_id": "default-pack"
  },
  "recommended_swarms": [
    { "id": "ai-swarm" }
  ],
  "post_clone_script": [
    "pnpm install",
    "cp .env.local.example .env.local"
  ]
}
