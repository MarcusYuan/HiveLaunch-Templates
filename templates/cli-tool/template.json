{
  "schema_version": "2.0",
  "id": "cli-tool",
  "name": "CLI 工具",
  "description": "oclif + TypeScript + Inquirer - 现代 CLI 开发框架",
  "category": "tool",
  "phase": 3,
  "icon": "🖥️",
  "source": {
    "repo_url": "https://github.com/MarcusYuan/HiveLaunch",
    "template_path": "templates/cli-tool",
    "default_ref": "main"
  },
  "variables": [
    {
      "key": "PROJECT_NAME",
      "label": "项目名称",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "placeholder": "my-cli-tool",
      "description": "项目名称，仅小写字母、数字和连字符"
    },
    {
      "key": "DISPLAY_NAME",
      "label": "显示名称",
      "type": "string",
      "placeholder": "My CLI Tool",
      "description": "CLI 显示的名称 (用于 help)"
    },
    {
      "key": "BIN_NAME",
      "label": "命令名",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "placeholder": "mycli",
      "description": "CLI 可执行命令名"
    },
    {
      "key": "DESCRIPTION",
      "label": "描述",
      "type": "string",
      "placeholder": "A brief description of your CLI tool",
      "description": "CLI 的简短描述"
    },
    {
      "key": "VERSION",
      "label": "版本号",
      "type": "string",
      "default": "0.1.0",
      "description": "CLI 版本"
    }
  ],
  "files": [
    {
      "template": "package.json.tmpl",
      "output": "package.json"
    }
  ],
  "runtimes": [
    { "id": "opencode", "name": "OpenCode", "config_refs": [".opencode/oh-my-opencode.jsonc", "opencode.json"] }
  ],
  "agent_packs": [
    { "id": "default-pack", "name": "Default Agent Pack", "compatible_runtimes": ["opencode"], "artifact_refs": ["AGENTS.md", "CLAUDE.md", ".opencode/skills/"] }
  ],
  "skills": [
    "typescript-expert"
  ],
  "defaults": {
    "runtime_id": "opencode",
    "agent_pack_id": "default-pack"
  },
  "recommended_swarms": [
    { "id": "cli-tool-swarm" }
  ],
  "post_clone_script": [
    "pnpm install"
  ]
}
