{
  "schema_version": "2.0",
  "id": "blog-content",
  "name": "博客/内容站",
  "description": "Astro 5 + MDX + Tailwind CSS",
  "category": "content",
  "phase": 2,
  "icon": "📝",
  "source": {
    "repo_url": "https://github.com/MarcusYuan/HiveLaunch-Templates",
    "template_path": "templates/blog-content",
    "default_ref": "main"
  },
  "variables": [
    { "key": "PROJECT_NAME", "label": "项目名称", "type": "string" },
    { "key": "DOMAIN", "label": "域名", "type": "string", "placeholder": "example.com" }
  ],
  "files": [{ "template": "package.json.tmpl", "output": "package.json" }],
  "runtimes": [
    { "id": "opencode", "name": "OpenCode", "config_refs": [".opencode/oh-my-opencode.jsonc", "opencode.json"] }
  ],
  "agent_packs": [
    { "id": "default-pack", "name": "Default Agent Pack", "compatible_runtimes": ["opencode"], "artifact_refs": ["AGENTS.md", "CLAUDE.md", ".opencode/skills/"] }
  ],
  "skills": [
    "typescript-expert",
    "tailwind-v4-shadcn"
  ],
  "defaults": {
    "runtime_id": "opencode",
    "agent_pack_id": "default-pack"
  },
  "post_clone_script": ["pnpm install"]
}
