    "@hono/trpc-server": "^0.4.0",
    "@hivelaunch/database": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "zod": "^3.24.0",
    "@types/node": "^20.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
